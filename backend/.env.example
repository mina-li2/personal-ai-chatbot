# Copy this file to .env and fill in your real values. Never commit .env itself.

# Copy this file to .env and fill in your real values. Never commit .env itself.

DATABASE_URL=postgresql://chatbot:chatbot_pw@db:5432/chatbot_db

# Which LLM backend to use: "groq" (default, free hosted API) or "ollama" (fully local)
LLM_PROVIDER=groq

# Needed only if LLM_PROVIDER=groq. Get a free key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Needed only if LLM_PROVIDER=ollama. Install Ollama and run `ollama pull llama3.1` first.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

